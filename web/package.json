{
  "name": "@conduitio/conduit-connector-registry-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Static site generated at build time from the signed connector registry index. No backend, no client-side fetch-and-render — real HTML per connector, crawlable and agent-legible.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "tsx scripts/build-site.ts",
    "astro:build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "axe": "tsx scripts/axe-scan.ts",
    "smoke:deployed": "tsx scripts/post-deploy-smoke.ts",
    "check:tokens": "tsx scripts/check-token-drift.ts"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "astro": "^7.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.20.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/semver": "^7.5.8",
    "axe-core": "^4.12.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
