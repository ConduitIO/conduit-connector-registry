---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadRenderModel } from '../lib/loadRenderModel';
import { closestNames } from '../lib/levenshtein';

const model = loadRenderModel();
const path = Astro.url.pathname;
const match = /\/connectors\/([^/]+)\/?$/.exec(path);
const attemptedName = match?.[1] ? decodeURIComponent(match[1]) : undefined;
const suggestions = attemptedName
  ? closestNames(
      attemptedName,
      model.connectors.map((c) => c.name)
    )
  : [];
---

<BaseLayout title="Not found — Conduit connector registry">
  <h1>Page not found</h1>
  {
    attemptedName ? (
      <p>
        No connector named <code>{attemptedName}</code> is in the registry.
      </p>
    ) : (
      <p>That page doesn't exist.</p>
    )
  }
  {
    suggestions.length > 0 && (
      <>
        <p>Did you mean:</p>
        <ul>
          {suggestions.map((name) => (
            <li>
              <a href={`/connectors/${name}/`}>{name}</a>
            </li>
          ))}
        </ul>
      </>
    )
  }
  <p><a href="/">Browse all connectors</a></p>
</BaseLayout>
